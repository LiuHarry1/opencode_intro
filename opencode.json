{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
      "copilot-api": {
        "npm": "@ai-sdk/openai-compatible",
        "name": "copilot-api",
        "options": {
          "baseURL": "http://host.docker.internal:4141"
        },
        "models": {
          "gpt-5.2": {
            "name": "GPT-5.2"
          },
          "gpt-4": {
            "name": "GPT-4"
          }
        }
      }
    },
    "model":"copilot-api/gpt-5.2",

    "permission": {
      "skill": {
        "*": "allow"
      },
      "file": {
        "read": "allow",
        "write": "allow"
      },
      "shell": "allow"
    },

    "lsp": {
        "pyright": {
            "disabled": true
        },
        "custom-python-lsp": {
            "command": ["python", "/workspace/.opencode/lsp/custom_lsp_server.py"],
            "extensions": [".py"]
        }
    },

   "mcp": {
        "chrome-devtools": {
        "type": "local",
        "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
        "enabled": true,
        "timeout": 30000
    }
  }

  
  }
  